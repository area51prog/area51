# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real secrets.

# Finnhub (https://finnhub.io) — used as a fallback live-quote provider.
# Free tier covers US tickers only; NSE/BSE symbols will fall back to mock data.
FINNHUB_API_KEY=

# Upstox developer app (https://upstox.com/developer) — primary NSE quote provider.
# Redirect URI must exactly match what's registered in the Upstox app console.
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:3000/api/upstox/callback

# Supabase project (https://supabase.com/dashboard) — auth + database.
# Find these under Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
